include MANIFEST.in
include LICENSE
include pyproject.toml
include README.md
recursive-include src/ffpa_attn *.py
recursive-include csrc *.cu *.cuh *.h *.hpp *.cpp
recursive-include tests *.py
prune build
prune dist
prune docs/site
prune third_party
global-exclude *.o *.so *.dylib *.a .git *.pyc *.swp .gitignore *__pycache__
